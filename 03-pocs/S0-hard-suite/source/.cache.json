n    if den < 0:\n        num = -num\n        den = -den\n\n    return (num, den)\n```", "prompt_tokens": 79, "completion_tokens": 133, "billed_completion_tokens": 133, "total_tokens": 212, "finish_reason": "stop", "raw_usage": {"prompt_tokens": 79, "completion_tokens": 133, "total_tokens": 212, "prompt_tokens_details": {"cached_tokens": 0, "audio_tokens": 0}, "completion_tokens_details": {"reasoning_tokens": 21, "audio_tokens": 0, "accepted_prediction_tokens": 0, "rejected_prediction_tokens": 0}}, "native_cost_usd": null, "latency_ms": 4026, "provider": "openai", "usd": 0.004385, "cached": false}, "09bf2753f3e4dd5c7533b9bcec4064cdf9cbaf07c462a749bde256868eaf4f4b": {"model": "gpt-5.5", "text": "```python\ndef days_between(y1, m1, d1, y2, m2, d2) -> int:\n    def days_before_year(y: int) -> int:\n        y -= 1\n        return 365 * y + y // 4 - y // 100 + y // 400\n\n    def is_leap(y: int) -> bool:\n        return y % 4 == 0 and (y % 100 != 0 or y % 400 == 0)\n\n    def day_of_year(y: int, m: int, d: int) -> int:\n        month_days = [31, 28 + is_leap(y), 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]\n        return sum(month_days[:m - 1]) + d\n\n    def ordinal(y: int, m: int, d: int) -> int:\n        return days_before_year(y) + day_of_year(y, m, d)\n\n    return abs(ordinal(y1, m1, d1) - ordinal(y2, m2, d2))\n```", "prompt_tokens": 69, "completion_tokens": 298, "billed_completion_tokens": 298, "total_tokens": 367, "finish_reason": "stop", "raw_usage": {"prompt_tokens": 69, "completion_tokens": 298, "total_tokens": 367, "prompt_tokens_details": {"cached_tokens": 0, "audio_tokens": 0}, "completion_tokens_details": {"reasoning_tokens": 43, "audio_tokens": 0, "accepted_prediction_tokens": 0, "rejected_prediction_tokens": 0}}, "native_cost_usd": null, "latency_ms": 5214, "provider": "openai", "usd": 0.009285, "cached": false}, "4c244cd5013b6f7ea5154af709b41b605e328dc5c9801ae5fece5215f869bf0b": {"model": "gpt-5.5", "text": "```python\ndef to_base(n: int, b: int) -> str:\n    if not (2 <= b <= 36):\n        raise ValueError(\"base must be between 2 and 36\")\n\n    if n == 0:\n        return \"0\"\n\n    digits = \"0123456789abcdefghijklmnopqrstuvwxyz\"\n    sign = \"-\" if n < 0 else \"\"\n    n = abs(n)\n\n    result = []\n    while n:\n        n, rem = divmod(n, b)\n        result.append(digits[rem])\n\n    return sign + \"\".join(reversed(result))\n```", "prompt_tokens": 78, "completion_tokens": 159, "billed_completion_tokens": 159, "total_tokens": 237, "finish_reason": "stop", "raw_usage": {"prompt_tokens": 78, "completion_tokens": 159, "total_tokens": 237, "prompt_tokens_details": {"cached_tokens": 0, "audio_tokens": 0}, "completion_tokens_details": {"reasoning_tokens": 30, "audio_tokens": 0, "accepted_prediction_tokens": 0, "rejected_prediction_tokens": 0}}, "native_cost_usd": null, "latency_ms": 3090, "provider": "openai", "usd": 0.00516, "cached": false}, "80dcd30a5c79cd58663e1fc2e8a0bf13e88b92b86ac1a5a9177d7d84127f0a49": {"model": "gpt-5.5", "text": "9", "prompt_tokens": 32, "completion_tokens": 22, "billed_completion_tokens": 22, "total_tokens": 54, "finish_reason": "stop", "raw_usage": {"prompt_tokens": 32, "completion_tokens": 22, "total_tokens": 54, "prompt_tokens_details": {"cached_tokens": 0, "audio_tokens": 0}, "completion_tokens_details": {"reasoning_tokens": 12, "audio_tokens": 0, "accepted_prediction_tokens": 0, "rejected_prediction_tokens": 0}}, "native_cost_usd": null, "latency_ms": 1414, "provider": "openai", "usd": 0.00082, "cached": false}, "c77fd44cdca77b0206cd2f4465d7a58b96941d154f8e69bf25849de346dc19e5": {"model": "gpt-5.5", "text": "2nd", "prompt_tokens": 48, "completion_tokens": 25, "billed_completion_tokens": 25, "total_tokens": 73, "finish_reason": "stop", "raw_usage": {"prompt_tokens": 48, "completion_tokens": 25, "total_tokens": 73, "prompt_tokens_details": {"cached_tokens": 0, "audio_tokens": 0}, "completion_tokens_details": {"reasoning_tokens": 14, "audio_tokens": 0, "accepted_prediction_tokens": 0,